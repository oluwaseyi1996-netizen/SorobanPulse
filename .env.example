# PostgreSQL credentials (used by both the db service and the app's DATABASE_URL)
POSTGRES_USER=<USER>
POSTGRES_PASSWORD=<PASSWORD>
POSTGRES_DB=soroban_pulse

# Deployment environment (development / staging / production)
# Controls strictness of CORS and other defaults.
ENVIRONMENT=development

# PostgreSQL connection string — must match the credentials above
# Format: postgres://<POSTGRES_USER>:<POSTGRES_PASSWORD>@db:5432/<POSTGRES_DB>
DATABASE_URL=postgres://<USER>:<PASSWORD>@db:5432/soroban_pulse

# Optional: read DATABASE_URL from a file (Docker secrets / Kubernetes secret mount)
# When set, this takes precedence over DATABASE_URL
# DATABASE_URL_FILE=/run/secrets/database_url

# PostgreSQL connection pool sizing
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2

# Maximum time (ms) a single DB statement may run before Postgres cancels it.
# Prevents slow queries from holding pool connections indefinitely.
# Format: integer milliseconds (e.g., 5000 = 5 seconds)
DB_STATEMENT_TIMEOUT_MS=5000

# Timeout (ms) for the health check DB ping (SELECT 1).
# Increase for databases under heavy load; decrease for latency-sensitive probes.
# Format: integer milliseconds (e.g., 2000 = 2 seconds)
HEALTH_CHECK_TIMEOUT_MS=2000

# Soroban RPC endpoint URL — must be a valid HTTPS URL in production
# Format: https://<domain> or http://<ip>:<port>
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Allow HTTP or loopback/private RPC URLs (local dev only — never set in production)
# ALLOW_INSECURE_RPC=true

# Ledger sequence number to start indexing from (0 = latest)
# Format: integer (e.g., 0, 123456)
START_LEDGER=0

# HTTP server port to listen on
# Format: integer (e.g., 3000, 8080)
PORT=3000

# Rust logging level configuration — controls what the service prints to stdout.
# Without this set, you will see NO log output. Set to "info" for normal operation.
# The service defaults to "info" internally, but setting it here makes it explicit.
# Format: string (trace, debug, info, warn, error)
RUST_LOG=info

# Sampling rate for debug-level logs (1 = log everything, 100 = log 1%).
# Only applies to debug! log lines; info! and above are never sampled.
# Format: positive integer (default: 1)
LOG_SAMPLE_RATE=1

# Optional API Key for authenticating endpoints
# If left unset, authentication is bypassed entirely.
# Format: string (e.g., your-super-secret-key-123)
# API_KEY=

# Optional secondary API key for rotation without service restart
# When set, both API_KEY and API_KEY_SECONDARY are accepted simultaneously.
# Allows operators to distribute a new key to clients before removing the old one.
# Format: string (e.g., your-new-secret-key-456)
# API_KEY_SECONDARY=

# Allowed CORS origins (comma-separated). Use * to allow all origins (local dev only).
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

# Per-IP rate limit (requests per minute). Exceeding this returns 429 with Retry-After.
RATE_LIMIT_PER_MINUTE=60

# Indexer lag warning threshold (ledgers). Warns when indexer falls behind by this many ledgers.
# Format: integer (e.g., 100, 500)
INDEXER_LAG_WARN_THRESHOLD=100

# Indexer poll interval when no new ledgers are available (milliseconds).
# Lower values reduce event propagation latency; higher values reduce RPC API usage.
# Valid range: 100–60000 ms
INDEXER_POLL_INTERVAL_MS=5000

# Indexer backoff duration after an RPC error (milliseconds).
# Valid range: 100–60000 ms
INDEXER_ERROR_BACKOFF_MS=10000

# SSE keep-alive comment interval (milliseconds).
# Controls how often a ": ping" comment is sent to prevent proxy idle-connection timeouts.
# Set below your reverse proxy's idle timeout (nginx/ALB default is often 60 s).
# Valid range: 1000–60000 ms
SSE_KEEPALIVE_INTERVAL_MS=15000

# Log output format (text or json)
# Format: string (text, json)
RUST_LOG_FORMAT=text

# OpenTelemetry OTLP exporter endpoint (when built with otel feature)
# When enabled, traces include:
# - HTTP request spans with method, route, and status code
# - RPC call spans with URL and response metadata
# - Database query spans with SQL statement, row count, and execution duration
# Format: URL (e.g., http://localhost:4317)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Optional read replica URL for PostgreSQL.
# When set, all HTTP read queries (event list, contract events, tx events) use this pool.
# The indexer always uses the primary DATABASE_URL for writes.
# When unset, all queries use the primary pool (backward compatible).
# Format: postgres://<USER>:<PASSWORD>@<HOST>:5432/<DB>
# DATABASE_REPLICA_URL=postgres://<USER>:<PASSWORD>@replica:5432/soroban_pulse

# Event types the indexer fetches from the Soroban RPC getEvents endpoint.
# Comma-separated list of: contract, diagnostic, system
# Default (unset): all types are fetched (backward compatible).
# Set to a subset to reduce storage and bandwidth for deployments that only need contract events.
# Invalid values cause a startup panic with a descriptive message.
# INDEXER_EVENT_TYPES=contract

# Custom headers to inject into every Soroban RPC request.
# Semicolon-separated list of "Name: Value" pairs.
# Use this for authenticated RPC providers that require API keys or Authorization headers.
# Header values are never logged at any log level.
# Invalid format causes a startup panic with a descriptive message.
# STELLAR_RPC_HEADERS=X-API-Key: mykey; X-Custom: value
